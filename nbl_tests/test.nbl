# Comment
#-
    This is a
    multi line comment
-#

local var = 10
global var = 10

component StyledButton (bg_color?) {
    Object "id" {
        # Simple default value pattern
        background = bg_color || "#ffffff"
    }
}

component LooseStyledButton (any: test) {
    # ?. makes it null if it even if doesn't exist
    local bg_color = test?.bg_color

    Object "id" {
        # Simple default value pattern
        background = bg_color || "#ffffff"
    }
}

fn show() {
    StyledButton {
        bg_color = "#000000"
    }
}

LooseStyledButton {
}