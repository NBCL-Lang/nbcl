import std.math

local var = 1
global var = if true {
    math.abs(0 - 10)
} else {
    5
}

print(var)

component StyledButton (bg_color?) {
    Object "id" {
        # Simple default value pattern
        background = bg_color || "#ffffff"
    }
}

component LooseStyledButton (any: test) {
    # '?.' makes it null if it doesn't exist
    local bg_color = test?.bg_color
    id_required = true
    child_count = 1

    Object self.id {
        # Simple default value pattern
        background = bg_color || "#ffffff"

        self.children
    }
}

fn show() {
    StyledButton {
        bg_color = "#000000"
    }
}

LooseStyledButton "id" {
    Object {}
}